{
  "name": "lit-ui-editor",
  "version": "0.1.4",
  "description": "Lit web component content editor for plain JavaScript and Vue apps.",
  "keywords": [
    "cms",
    "editor",
    "lit",
    "vue",
    "web-components"
  ],
  "homepage": "https://github.com/tunlinphyo/lit-ui-editor#readme",
  "bugs": {
    "url": "https://github.com/tunlinphyo/lit-ui-editor/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tunlinphyo/lit-ui-editor.git"
  },
  "files": [
    "dist",
    "src",
    "!src/**/*.test.js",
    "README.md"
  ],
  "type": "module",
  "sideEffects": [
    "*.css",
    "src/**/*.css",
    "src/**/*.js"
  ],
  "main": "./dist/lit-ui-editor.js",
  "module": "./dist/lit-ui-editor.js",
  "exports": {
    ".": {
      "import": "./dist/lit-ui-editor.js",
      "default": "./dist/lit-ui-editor.js"
    },
    "./vue": {
      "import": "./dist/vue.js",
      "default": "./dist/vue.js"
    },
    "./style.css": "./dist/assets/lit-ui-editor.css",
    "./src/*": "./src/*"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "dev": "vp dev",
    "build": "vp build",
    "preview": "vp preview",
    "test": "vitest run",
    "test:text": "vitest run src/components/blocks/text/*.test.js",
    "test:watch": "vitest",
    "check": "vp check",
    "lint": "vp lint",
    "fmt": "vp fmt",
    "publish:dry-run": "npm pack --dry-run",
    "prepack": "vp build"
  },
  "dependencies": {
    "@vaadin/rich-text-editor": "^25.1.4",
    "lit": "^3.3.3"
  },
  "devDependencies": {
    "happy-dom": "^20.0.10",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    }
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest"
  },
  "packageManager": "npm@11.16.0"
}
